#!/usr/bin/env ruby
# frozen_string_literal: true

require 'English'
require 'json'
require 'open3'
require 'time'

CACHE = ARGV.delete('--no-cache') ? '--cache 1s' : '--cache 120s'
SHOW_DRAFTS = !ARGV.delete('--show-drafts').nil?
SHOW_CLOSED = !ARGV.delete('--show-closed').nil?

RESET   = "\e[0m"
DIM     = "\e[2m"
BOLD    = "\e[1m"
GREEN   = "\e[32m"
YELLOW  = "\e[33m"
CYAN    = "\e[36m"
MAGENTA = "\e[35m"

module OS
  def self.linux? = (/linux/ =~ RUBY_PLATFORM) != nil
  def self.open_cmd = linux? ? 'xdg-open' : 'open'
end

def fetch_notifications(all: false)
  # NOTE: -i (include HTTP headers) was removed to simplify parsing but could be re-added
  # to read X-Poll-Interval / X-Ratelimit-Remaining if needed in future.
  if all
    # Cap at 200 for "all" (includes read). Fetch pages until we reach 200 or hit a partial
    # page (signals last page), to avoid over-fetching. GitHub caps per_page at 50 for this
    # endpoint regardless of what we request.
    results = []
    page = 1
    loop do
      output = `gh api #{CACHE} 'notifications?all=true&page=#{page}'`
      exit 1 unless $CHILD_STATUS.success?
      batch = JSON.parse(output)
      results.concat(batch)
      break if results.size >= 200 || batch.size < 50

      page += 1
    end
    results.first(200)
  else
    # Unread only: paginate to ensure every unread notification is returned.
    # --jq '.[]' flattens each page's array so output is one JSON object per line.
    output = `gh api --paginate #{CACHE} --jq '.[]' 'notifications'`
    exit 1 unless $CHILD_STATUS.success?
    output.lines.map { |line| JSON.parse(line) }
  end
end

def tile_output(notifications)
  mentions = notifications.count { |notif| notif['reason'] == 'mention' }
  return if mentions.zero?

  puts "#[fg=#{ENV['accentText']},bold] @#{mentions}#[fg=#{ENV['statusSeparatorFg']}] │#[default]"
end

def api_path(url)
  url&.sub('https://api.github.com/', '')
end

def state_file_path = ENV['INBOX_STATE_FILE']

def read_state
  path = state_file_path
  return {} unless path && File.exist?(path)

  JSON.parse(File.read(path))
rescue JSON::ParserError
  {}
end

def write_state(state)
  path = state_file_path
  return unless path

  File.write(path, JSON.generate(state))
end

def mutate_state
  state = read_state
  yield state
  write_state(state)
end

def current_prompt
  state = read_state
  parts = [state['all'] ? 'All' : 'Unread']
  parts << '+drafts' if state['show_drafts']
  parts << '+closed' if state['show_closed']
  "#{parts.join(' ')}> "
end

def build_pr_graphql_query(pr_notifications)
  query_parts = []
  id_by_alias = {}
  pr_notifications.each_with_index do |notification, index|
    path = api_path(notification['subject']['url'])
    match = path&.match(%r{^repos/([^/]+)/([^/]+)/pulls/(\d+)$})
    next unless match

    owner, repository_name, number = match.captures
    alias_key = "pr#{index}"
    id_by_alias[alias_key] = notification['id']
    query_parts << "#{alias_key}: repository(owner: #{JSON.generate(owner)}, " \
                   "name: #{JSON.generate(repository_name)}) " \
                   "{ pullRequest(number: #{number}) { isDraft state author { login } } }"
  end
  [query_parts, id_by_alias]
end

def execute_graphql_query(query)
  command = %w[gh api graphql] + CACHE.split + ['-f', "query=#{query}"]
  output, status = Open3.capture2(*command)
  return nil unless status.success?

  JSON.parse(output)
rescue JSON::ParserError
  nil
end

def fetch_pull_request_statuses(pr_notifications)
  return {} if pr_notifications.empty?

  query_parts, id_by_alias = build_pr_graphql_query(pr_notifications)
  return {} if query_parts.empty?

  parsed = execute_graphql_query("query { #{query_parts.join(' ')} }")
  return {} unless parsed.is_a?(Hash)

  data = parsed['data'] || {}
  id_by_alias.each_with_object({}) do |(alias_key, notification_id), statuses|
    pull_request = data.dig(alias_key, 'pullRequest')
    next unless pull_request

    statuses[notification_id] = {
      is_draft: pull_request['isDraft'] == true,
      state: pull_request['state'],
      author: pull_request.dig('author', 'login')
    }
  end
end

def hide_pr?(status, show_drafts:, show_closed:)
  hide_for_draft  = !show_drafts && status[:is_draft]
  hide_for_closed = !show_closed && status[:state] && status[:state] != 'OPEN'
  hide_for_draft || hide_for_closed
end

def filter_pull_requests(notifications, statuses, show_drafts:, show_closed:)
  return notifications if show_drafts && show_closed
  return notifications if statuses.empty?

  notifications.reject do |notification|
    status = statuses[notification['id']]
    status && hide_pr?(status, show_drafts:, show_closed:)
  end
end

TYPE_BADGES = {
  'PullRequest' => ['PR', "#{CYAN}PR#{RESET}"],
  'Issue' => ['IS', "#{GREEN}IS#{RESET}"],
  'Release' => ['RL', "#{YELLOW}RL#{RESET}"],
  'Commit' => ['CM', "#{DIM}CM#{RESET}"],
  'Discussion' => ['DS', "#{DIM}DS#{RESET}"]
}.freeze

def type_badge(type)
  TYPE_BADGES[type] || ['??', "#{DIM}??#{RESET}"]
end

REASON_LABELS = {
  'review_requested' => 'review'
}.freeze

def reason_badge(reason)
  label = REASON_LABELS[reason] || reason
  colored = reason == 'mention' ? "#{MAGENTA}#{label}#{RESET}" : "#{DIM}#{label}#{RESET}"
  [label, colored]
end

def truncate(str, max)
  str.length <= max ? str : "#{str[0, max - 1]}…"
end

def format_relative_time(timestamp)
  return '' unless timestamp

  updated = Time.parse(timestamp)
  diff = Time.now - updated
  return 'now' if diff < 60
  return "#{(diff / 60).floor}m" if diff < 3600
  return "#{(diff / 3600).floor}h" if diff < 86_400
  return "#{(diff / 86_400).floor}d" if diff < 604_800

  "#{(diff / 604_800).floor}w"
rescue ArgumentError
  ''
end

MAX_REPO  = 35
MAX_TITLE = 55

def rate_limit_line
  output = `gh api rate_limit --jq '.rate | "\\(.remaining) \\(.limit)"' 2>/dev/null`
  return "_  _  #{DIM}API: ?#{RESET}" unless $CHILD_STATUS.success?

  remaining, limit = output.chomp.split.map(&:to_i)
  return "_  _  #{DIM}API: ?#{RESET}" if limit.zero?

  used = limit - remaining
  percentage = (used * 100.0 / limit).round
  "_  _  #{DIM}API: #{used}/#{limit} (#{percentage}%)#{RESET}"
end

def row_for(notification, pr_statuses)
  author_login = pr_statuses.dig(notification['id'], :author)
  {
    id: notification['id'],
    path: api_path(notification['subject']['url']) || '_',
    repo: truncate(notification['repository']['full_name'], MAX_REPO),
    type: type_badge(notification['subject']['type']),
    reason: reason_badge(notification['reason']),
    author: author_login ? "@#{author_login}" : '',
    title: truncate(notification['subject']['title'], MAX_TITLE),
    updated: format_relative_time(notification['updated_at'])
  }
end

def format_row(row, widths)
  repo_pad   = row[:repo].ljust(widths[:repo])
  reason_pad = row[:reason][1] + ' ' * (widths[:reason] - row[:reason][0].length)
  author_colored = row[:author].empty? ? '' : "#{DIM}#{row[:author]}#{RESET}"
  author_pad = author_colored + ' ' * (widths[:author] - row[:author].length)
  title_pad  = row[:title].ljust(widths[:title])
  updated_pad = "#{DIM}#{row[:updated].rjust(widths[:updated])}#{RESET}"

  visible = [
    "#{BOLD}#{repo_pad}#{RESET}",
    row[:type][1],
    reason_pad,
    title_pad,
    author_pad,
    updated_pad
  ].join('  ')

  { line: "#{row[:id]}  #{row[:path]}  #{visible}", path: row[:path] }
end

def max_width(data, &)
  data.map(&).max || 0
end

def column_widths(data)
  {
    repo: max_width(data) { |row| row[:repo].length },
    reason: max_width(data) { |row| row[:reason][0].length },
    author: max_width(data) { |row| row[:author].length },
    title: max_width(data) { |row| row[:title].length },
    updated: max_width(data) { |row| row[:updated].length }
  }
end

def build_rows(notifications, pr_statuses = {})
  data = notifications
         .reject { |notification| notification['subject']['type'] == 'CheckSuite' }
         .map { |notification| row_for(notification, pr_statuses) }

  widths = column_widths(data)
  data.map { |row| format_row(row, widths) }
end

PREVIEW_CMD = <<~'SH'.chomp
  reset=$(printf '\033[0m')
  dim=$(printf '\033[2m')
  bold=$(printf '\033[1m')
  red=$(printf '\033[31m')
  green=$(printf '\033[32m')
  yellow=$(printf '\033[33m')
  magenta=$(printf '\033[35m')
  cyan=$(printf '\033[36m')
  grey=$(printf '\033[90m')
  notifurl="{2}"
  notifurl="${notifurl//\'/}"
  reviews='[]'
  case "$notifurl" in */pulls/*)
    reviews=$(gh api --cache 120s "${notifurl}/reviews" 2>/dev/null)
    [ -z "$reviews" ] && reviews='[]'
  esac
  gh api --cache 120s {2} 2>/dev/null | jq -r \
    --arg reset "$reset" \
    --arg dim "$dim" \
    --arg bold "$bold" \
    --arg red "$red" \
    --arg green "$green" \
    --arg yellow "$yellow" \
    --arg magenta "$magenta" \
    --arg cyan "$cyan" \
    --arg grey "$grey" \
    --argjson reviews "$reviews" \
    'if .message then
      ($dim + "No details available (\(.message))" + $reset)
    else
      (if (.merged // false) then ($magenta + "MERGED" + $reset)
      elif (.draft // false) then ($grey + "DRAFT" + $reset)
      elif .state == "open" then ($green + "OPEN" + $reset)
      elif .state == "closed" then ($red + "CLOSED" + $reset)
      else ($dim + "N/A" + $reset) end) as $state |
      (($reviews | if type == "array" then . else [] end |
        map(select(.state == "APPROVED" or .state == "CHANGES_REQUESTED")) |
        group_by(.user.login) | map(sort_by(.submitted_at) | last)) as $latest_reviews |
        ($latest_reviews | map(select(.state == "APPROVED") | .user.login)) as $approvers |
        ($latest_reviews | map(select(.state == "CHANGES_REQUESTED") | .user.login)) as $requesters |
        { state: (if ($latest_reviews | length) == 0 then null
                  elif ($requesters | length) > 0 and ($approvers | length) == 0 then "changes_requested"
                  elif ($requesters | length) == 0 then "approved"
                  else "mixed" end),
          approvers: $approvers, requesters: $requesters }) as $review |
      ($bold + (.title // .name // "(untitled)") + $reset),
      ($state + (if .number then "  #\(.number | tostring)" else "" end) + "  " + $cyan + "@" + (.user.login // .author.login // "unknown") + $reset),
      (if .updated_at then
        ((.updated_at | strptime("%Y-%m-%dT%H:%M:%SZ") | mktime) as $updated_ts |
        (now - $updated_ts) as $diff |
        if $diff < 14400 then
          if $diff < 3600 then ($diff / 60 | floor | tostring) + "m ago"
          else ($diff / 3600 | floor | tostring) + "h ago"
          end
        else (.updated_at | strptime("%Y-%m-%dT%H:%M:%SZ") | strftime("%d.%m.%Y %H:%M"))
        end) as $updated_str |
        ($dim + "Updated:" + $reset + "   " + $updated_str)
      else empty end),
      (if .changed_files then ($dim + "Files:" + $reset + "     \(.changed_files)  " + $green + "+\(.additions)" + $reset + "  " + $red + "-\(.deletions)" + $reset) else empty end),
      (if $review.state == "approved" then
         ($dim + "Reviews:" + $reset + "   " + $green + "✓ " + ($review.approvers | join(", ")) + $reset)
       elif $review.state == "changes_requested" then
         ($dim + "Reviews:" + $reset + "   " + $red + "✗ " + ($review.requesters | join(", ")) + $reset +
          (if ($review.approvers | length) > 0 then "  " + $green + "✓ " + ($review.approvers | join(", ")) + $reset else "" end))
       elif $review.state == "mixed" then
         ($dim + "Reviews:" + $reset + "   " + $green + "✓ " + ($review.approvers | join(", ")) + $reset +
          "  " + $red + "✗ " + ($review.requesters | join(", ")) + $reset)
       elif (.review_comments // 0) > 0 then ($dim + "Reviews:" + $reset + "   \(.review_comments) comment\(if .review_comments == 1 then "" else "s" end)")
       else empty end),
      (if ((.labels // []) | length) > 0 then ($dim + "Labels:" + $reset + "    \(.labels | map(.name) | join(", "))") else empty end),
      (if ((.assignees // []) | length) > 0 then ($dim + "Assignees:" + $reset + " \(.assignees | map(.login) | join(", "))") else empty end),
      "",
      (.body // "(no description)")
    end'
SH

def fzf_pick(rows)
  script = File.expand_path(__FILE__)
  mark_read_cmd = "printf '%s\\n' {+1} | xargs -I{} gh api --method PATCH notifications/threads/{}"
  refresh_prompt = "transform-prompt(#{script} --prompt)"
  header_lines = [
    'u: all/unread  d: drafts  p: closed/merged',
    'r: mark read  o: open in browser  f: fullscreen'
  ].join("\n")
  zoom_layouts = 'hidden|right:40%:wrap'
  flags = ['fzf', '--ansi', '--multi',
           '--header-lines=1',
           "--prompt=#{current_prompt}",
           "--header=#{header_lines}",
           "--bind=ctrl-u:execute-silent(#{script} --toggle all)+#{refresh_prompt}+reload(#{script} --rows)",
           "--bind=ctrl-d:execute-silent(#{script} --toggle show_drafts)+#{refresh_prompt}+reload(#{script} --rows)",
           "--bind=ctrl-p:execute-silent(#{script} --toggle show_closed)+#{refresh_prompt}+reload(#{script} --rows)",
           "--bind=ctrl-r:execute-silent(#{mark_read_cmd})+reload(#{script} --rows --no-cache)",
           "--bind=ctrl-o:execute-silent(#{OS.open_cmd} https://github.com/notifications)+abort",
           "--bind=ctrl-f:change-preview-window(#{zoom_layouts})",
           "--preview=#{PREVIEW_CMD}",
           '--preview-window=right:40%:wrap',
           '--with-nth=3..']

  (IO.popen(flags, 'r+') do |io|
    io.puts rate_limit_line
    rows.each { |row| io.puts row[:line] }
    io.close_write
    io.read.lines.map { |line| line.chomp.split('  ', 3)[1] }.compact
  end) || []
rescue Errno::EPIPE
  []
end

has_toggle         = ARGV.include?('--toggle')
has_rows           = ARGV.include?('--rows')
has_prompt         = ARGV.include?('--prompt')
has_tile           = ARGV[0] == 'tile'
is_state_mutation  = has_toggle
is_subcommand_invocation = has_rows || has_prompt || has_tile || is_state_mutation

unless is_subcommand_invocation
  ENV['INBOX_STATE_FILE'] = "/tmp/github-inbox-#{Process.pid}.state"
  initial_state = {
    'all' => ARGV.include?('--all'),
    'show_drafts' => SHOW_DRAFTS,
    'show_closed' => SHOW_CLOSED
  }
  File.write(ENV['INBOX_STATE_FILE'], JSON.generate(initial_state))
  at_exit do
    File.delete(ENV['INBOX_STATE_FILE'])
  rescue Errno::ENOENT
    nil
  end
end

if (toggle_index = ARGV.index('--toggle'))
  ARGV.delete_at(toggle_index)
  toggle_key = ARGV.delete_at(toggle_index)
  mutate_state { |state| state[toggle_key] = !state[toggle_key] } if %w[all show_drafts show_closed].include?(toggle_key)
end

if has_prompt
  puts current_prompt
  exit 0
end

exit 0 if is_state_mutation && !has_rows && !has_tile

if state_file_path && File.exist?(state_file_path)
  state = read_state
  all          = state['all'] == true
  show_drafts  = state['show_drafts'] == true
  show_closed  = state['show_closed'] == true
else
  all          = ARGV.include?('--all')
  show_drafts  = SHOW_DRAFTS
  show_closed  = SHOW_CLOSED
end

notifications = fetch_notifications(all:)

if ARGV[0] == 'tile'
  tile_output(notifications)
  exit 0
end

pr_notifications = notifications.select { |notification| notification['subject']['type'] == 'PullRequest' }
pr_statuses = fetch_pull_request_statuses(pr_notifications)

notifications = filter_pull_requests(notifications, pr_statuses, show_drafts:, show_closed:)

if ARGV.include?('--rows')
  puts rate_limit_line
  build_rows(notifications, pr_statuses).each { |row| puts row[:line] }
  exit 0
end

rows = build_rows(notifications, pr_statuses)
selected = fzf_pick(rows)

selected.each do |path|
  next if path == '_'

  html_url = `gh api #{CACHE} #{path} --jq .html_url`.chomp
  next if html_url.empty?

  system(OS.open_cmd, html_url)
end
