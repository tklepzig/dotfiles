{
  "version": "1.0.0",
  "manifest_version": 2,
  "name": "Toolbox",
  "short_name": "Toolbox",
  "start_url": "/",
  "display": "standalone",
  "orientation": "any",
  "theme_color": "#99cc66",
  "background_color": "#15160e",
  "icons": [
    {
      "src": "assets/logo-192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "assets/logo-512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "assets/logo-192-maskable.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "maskable"
    },
    {
      "src": "assets/logo-512-maskable.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "maskable"
    }
  ]
}
