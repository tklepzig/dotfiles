#!/usr/bin/env zsh

defaultBranch=$([ -f "$(git rev-parse --show-toplevel)/.git/refs/heads/master" ] && echo master || echo main)
currentBranch=$(git symbolic-ref --short HEAD)
baseBranch=${1:-$defaultBranch}

git fetch origin

# Update base branch if we're not on it
if [ "$currentBranch" != "$baseBranch" ]; then
    # Find the worktree where the base branch is checked out, works only for paths without spaces!!
    baseBranchWorktree=$(git worktree list | awk -v b="[$baseBranch]" '$3 == b {print $1}')

    if [ -n "$baseBranchWorktree" ]; then
        # Try to fast-forward the base branch in its worktree, if it fails (e.g. due to local changes), just skip it
        # GIT_DIR is set by git's ! alias execution, must unset it so -C discovers the correct .git in the target worktree
        if ! GIT_DIR= git -C "$baseBranchWorktree" merge --ff-only origin/$baseBranch 2>&1; then
            echo "Warning: Could not fast-forward $baseBranch in $baseBranchWorktree, skipping update"
        fi
    else
        # The base branch is not checked out in any worktree, we can safely update it
        git fetch origin +$baseBranch:$baseBranch
    fi
fi

git merge --ff-only
