#!/usr/bin/env zsh

default_branch=$(git rev-parse --verify --quiet refs/heads/master > /dev/null && echo master || echo main)
export GIT_BRANCH_DIFF_BASE="$default_branch"

selected_branch=$(
  git branch --format='%(refname:short)' \
    | grep -v "^${GIT_BRANCH_DIFF_BASE}$" \
    | fzf \
        --ansi \
        --prompt="branch> " \
        --preview='
          branch={}
          merge_base=$(git merge-base "$branch" "$GIT_BRANCH_DIFF_BASE")
          git log --oneline --color=always "${merge_base}..${branch}"
          echo
          git diff --numstat "${merge_base}..${branch}" | awk '"'"'BEGIN{green="\033[32m"; red="\033[31m"; reset="\033[0m"} {printf "%s+%s%s %s-%s%s  %s\n", green, $1, reset, red, $2, reset, $3}'"'"'
          echo
          git diff "${merge_base}..${branch}" | delta --side-by-side --width="$FZF_PREVIEW_COLUMNS"
        ' \
        --preview-window=right:80%
)

[[ -z "$selected_branch" ]] && exit 0

merge_base=$(git merge-base "$selected_branch" "$GIT_BRANCH_DIFF_BASE")
git diff "$merge_base".."$selected_branch" | delta --side-by-side --width="$(tput cols)" | less -R
