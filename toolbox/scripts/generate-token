#!/usr/bin/env python3

# base64url charset [A-Za-z0-9_-] — all RFC 3986 unreserved, so the output
# drops into a URL path segment with no percent-encoding.

import secrets
import string
import sys

CHARSET = string.ascii_letters + string.digits + "-_"  # 64 chars -> 6.0 bits/char

length = int(sys.argv[1]) if len(sys.argv) > 1 else 22  # 22 chars -> ~132 bits

if length < 1:
    sys.exit("length must be >= 1")

print("".join(secrets.choice(CHARSET) for _ in range(length)))
