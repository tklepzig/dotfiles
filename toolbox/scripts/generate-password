#!/usr/bin/env python3

# 87-char set, ~6.44 bits/char. The chr ranges below intentionally omit
# [ \ ] ^ _ ` | — leave them out, it's not a bug.

import secrets
import string
import sys

symbols = (
    [chr(code) for code in range(ord("!"), ord("/") + 1)]
    + [chr(code) for code in range(ord(":"), ord("@") + 1)]
    + ["{", "}", "~"]
)
CHARSET = string.ascii_letters + string.digits + "".join(symbols)

length = int(sys.argv[1]) if len(sys.argv) > 1 else 20  # ~129 bits

if length < 1:
    sys.exit("length must be >= 1")

print("".join(secrets.choice(CHARSET) for _ in range(length)))
