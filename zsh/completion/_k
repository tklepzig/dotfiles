#compdef k

_k() {
  if (( CURRENT == 2 )); then
    local -a subcommands
    subcommands=( ${(f)"$($dotfilesDir/toolbox/scripts/_run.rb --completion git-worktree-list)"} )
    _describe -t subcommands 'subcommands' subcommands
  elif [[ $words[2] == 'add' ]]; then
    if (( CURRENT == 3 )); then
      local -a branches
      # (f) splits output on newlines into array elements
      local -a local_branches remote_branches
      local_branches=( ${(f)"$(git for-each-ref --format='%(refname:strip=2)' refs/heads/ 2>/dev/null)"} )
      remote_branches=( ${(f)"$(git for-each-ref --format='%(refname:strip=3)' refs/remotes/origin/ 2>/dev/null)"} )
      branches=( $local_branches[@] $remote_branches[@] )
      # (u) deduplicates; ${...:#HEAD} removes the remote HEAD entry
      branches=( ${(u)branches[@]:#HEAD} )
      _describe -t branches 'branches' branches
    elif (( CURRENT >= 4 )); then
      local -a options
      options=('--no-cd:skip cd into new worktree')
      _describe -t options 'options' options
    fi
  fi
}

_k
